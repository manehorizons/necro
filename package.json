{
  "name": "@manehorizons/necro",
  "version": "1.2.0",
  "description": "Local, free, polyglot CLI that finds anti-pattern code and proposes LLM-assisted fixes.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "necro": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manehorizons/necro.git"
  },
  "homepage": "https://github.com/manehorizons/necro#readme",
  "bugs": {
    "url": "https://github.com/manehorizons/necro/issues"
  },
  "keywords": [
    "dead-code",
    "static-analysis",
    "typescript",
    "mcp",
    "code-quality",
    "duplication",
    "complexity",
    "refactor"
  ],
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --packages=external --banner:js='#!/usr/bin/env node' --outfile=dist/cli.js",
    "bench": "tsx src/bench/cli-bench.ts",
    "bench:checkout": "tsx src/bench/cli-checkout.ts",
    "bench:competitors": "tsx src/bench/cli-competitors.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "picomatch": "^4.0.4",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^24.0.0",
    "web-tree-sitter": "^0.25.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.19.42",
    "@types/picomatch": "^3.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.24.0",
    "knip": "^6.27.0",
    "ts-prune": "^0.10.3",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
