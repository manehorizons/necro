# necro — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
#
# NOTE: the test runner does NOT auto-load .env into process.env
# (no dotenv / no vitest setupFile). To run the live triage eval, SOURCE
# this file into your shell first, then run vitest:
#
#   set -a; source .env; set +a
#   npx vitest run test/triage-eval.live.test.ts
#
# Or inline it for a one-off (no .env needed):
#   ANTHROPIC_API_KEY=sk-... npx vitest run test/triage-eval.live.test.ts

# Anthropic API key — required ONLY for the live triage eval and the opt-in
# `necro triage` command against the real model. `scan`/`fix` never need it.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model / effort / maxFindings are NOT env vars — configure them in
# necro.config.json (defaults: model=claude-opus-4-8). See src/config.ts.
